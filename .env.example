# Redes
DOCKER_NETWORK=finance-network

# Configurações de Usuário (Exemplos)
MYSQL_ROOT_PASSWORD=root_pass
POSTGRES_PASSWORD=b3_pass
MONGO_INITDB_ROOT_PASSWORD=mongo_pass

# MySQL - Broker
#BROKER_IDENTITY_DB_NAME=broker_identity_db
BROKER_WALLET_DB_NAME=broker_wallet_db
BROKER_ORDER_DB_NAME=broker_order_db
BROKER_ASSET_DB_NAME=broker_asset_db

# Credenciais comuns para o Broker (simplifica sua POC)
BROKER_DB_USER=broker_user
BROKER_DB_PASS=broker_pass
BROKER_DB_ROOT_PASS=root_pass

# Postgres - B3
B3_CORE_DB=b3_core_db
B3_CORE_USER=b3_core_user
B3_CORE_PASSWORD=b3_core_password

# Redis
REDIS_PORT=6379

# MongoDB - Broker (Shared Instance)
MONGO_PORT=27017
MONGO_DB_MARKET=market_data_db
MONGO_DB_REPORT=report_db

# Redis - Instâncias Isoladas
REDIS_BROKER_ASSET_PORT=6379
REDIS_BROKER_WALLET_PORT=6380
REDIS_B3_MARKET_PORT=6381

# RabbitMQ
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin_pass
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# Kafka (KRaft)
KAFKA_PORT=9092
KAFKA_UI_PORT=8080
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Observabilidade
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000